<Window x:Class="NetBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetBar"
        Width="172" 
        Height="42"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border x:Name="RootBorder"
            Background="Transparent"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="Transparent"
            Margin="3">

        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="开机自启" 
                          IsCheckable="True" 
                          Click="AutoStart_Click" 
                          StaysOpenOnClick="True"
                          x:Name="MenuAutoStart"/>
                <Separator/>

                <MenuItem Header="主题">
                    <MenuItem Header="跟随系统" IsCheckable="True" Click="MenuThemeFollow_Click" StaysOpenOnClick="True" x:Name="MenuThemeFollow" />
                    <MenuItem Header="浅色" IsCheckable="True" Click="MenuThemeLight_Click" StaysOpenOnClick="True" x:Name="MenuThemeLight" />
                    <MenuItem Header="深色" IsCheckable="True" Click="MenuThemeDark_Click" StaysOpenOnClick="True" x:Name="MenuThemeDark" />
                </MenuItem>
                <MenuItem Header="左键移动窗口" IsCheckable="True" Click="MenuLeftMove_Click" StaysOpenOnClick="True" x:Name="MenuLeftMove" />
                <MenuItem Header="重置设置" Click="Reset_Click" />
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <Grid Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="DownloadText"
                       Text="↓ 0.0 K/s"
                       FontFamily="Segoe UI Variable Static, Microsoft YaHei UI"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       ToolTip="左键拖动 • 右键菜单"/>
            <TextBlock x:Name="UploadText"
                       Grid.Column="1"
                       Text="↑ 0.0 K/s"
                       FontFamily="Segoe UI Variable Static, Microsoft YaHei UI"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       ToolTip="左键拖动 • 右键菜单"/>
        </Grid>
    </Border>
</Window>